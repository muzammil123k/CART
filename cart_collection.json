    {
      "name": "Create Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Capture the ID from the response and save it as an environment variable\r",
              "var jsonData = pm.response.json();\r",
              "pm.environment.set(\"current_cart_id\", jsonData.id);\r",
              "console.log(\"Captured Cart ID: \" + jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"coupon\": null,\r\n  \"user_id\": 1\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/carts/",
          "host": [
