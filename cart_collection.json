    {
      "name": "Add Item to Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var expectedStatus = pm.iterationData.get(\"expected_status\");\r",
              "var testName = pm.iterationData.get(\"test_description\");\r",
              "\r",
              "pm.test(testName + \": Expected status \" + expectedStatus, function () {\r",
              "    pm.response.to.have.status(expectedStatus);\r",
              "});\r",
              "\r",
              "// If it's a 200 OK, prove that the server successfully fetched the price\r",
              "if (expectedStatus === 200) {\r",
              "    pm.test(testName + \": Server securely fetched price_at_addition\", function () {\r",
              "        var jsonData = pm.response.json();\r",
              "        pm.expect(jsonData).to.have.property('price_at_addition');\r",
              "        pm.expect(jsonData.price_at_addition).to.be.a('number');\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
